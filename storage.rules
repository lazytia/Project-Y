rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Each authenticated user can read/write their own onboarding documents
    match /staff_onboarding/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Cash payment attachments (ID photos, signatures). Any signed-in
    // user (owners/managers) can read; writes capped at 5 MB image.
    match /cash_payments/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    // HR note attachments — any signed-in user (owners/managers) can
    // read or write. Cap uploads at 5 MB and image types only.
    match /hr_notes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }
  }
}
