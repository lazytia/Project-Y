rules_version = '2';

service cloud.firestore {
  match /databases/project-y/documents {

    // Staff onboarding: each authenticated user can read/write their own doc
    match /staff_onboarding/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
