rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Owners are identified by the synthetic email we mint from usernames
    // (see src/lib/username.ts → usernameToEmail). Keep this list in sync with
    // OWNER_USERNAMES in src/lib/permissions.ts.
    function isOwner() {
      return request.auth != null
        && request.auth.token.email in [
          "tia@projecty.local",
          "yurica@projecty.local",
          "yurina@projecty.local",
          "eddie@projecty.local"
        ];
    }

    // Keep in sync with CHEF_USERNAMES in src/lib/permissions.ts
    function isChef() {
      return request.auth != null
        && request.auth.token.email in [
          "chinglam@projecty.local",
          "chuck@projecty.local"
        ];
    }

    // Staff onboarding:
    //  - Any signed-in user can read (manager view at /people/onboarding lists
    //    every doc; the app's sign-in is currently restricted to owner accounts).
    //  - Staff can write their OWN doc (onboarding form progress).
    //  - Owners can write ANY staff doc (seeding new staff accounts from the
    //    Staff + page, sending reminders, pruning invalid FCM tokens, etc.).
    match /staff_onboarding/{uid} {
      allow read: if request.auth != null;
      allow write: if isOwner() || isChef()
        || (request.auth != null && request.auth.uid == uid);
    }

    // Published rosters: weekly docs keyed by Monday ISO date. Manager
    // notes and per-day shift counts live here. Staff need read access
    // so the staff roster page can display the same data.
    match /rosters_published/{weekStartISO} {
      allow read: if request.auth != null;
      allow create: if isOwner()
        || (isChef() && request.resource.data.keys().hasOnly(["notes"]));
      allow update: if isOwner()
        || (isChef()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["notes"]));
      allow delete: if isOwner();
    }

    // Weekly Square gross sales — written by the Square sync job
    // (server) every cron tick. Read by the Insights dashboard.
    match /sales_weekly/{weekStartISO} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Weekly payroll totals — written by the Xero sync job (server)
    // or by an owner via a manual entry form, read by the Insights
    // dashboard. Documents are keyed by the Monday ISO date of the
    // pay-run's work week and contain { gross, super, payDate }.
    match /payroll_weekly/{weekStartISO} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Cash payments: owner + manager only. Tracks every recorded
    // cash payment to candidates or active employees.
    match /cash_payments/{paymentId} {
      allow read, write: if isOwner() || isChef();
    }

    // HR notes: manager-only. Each note records a Formal Warning,
    // Performance Review, Incident Report, or Other note for a staff
    // member. Staff never see this collection.
    match /hr_notes/{noteId} {
      allow read, write: if isOwner() || isChef();
    }

    // Notice Given: records employees who have submitted resignation notice.
    // Owner-only read/write.
    match /notice_given/{noticeId} {
      allow read, write: if isOwner() || isChef();
    }

    // Sold-out category definitions — static config written by owners,
    // read by all signed-in users.
    match /sold_out_categories/{docId} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Daily sold-out state — keyed by YYYY-MM-DD. A missing doc means
    // nothing is sold out for that day (auto-reset by date change).
    match /sold_out_daily/{docId} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Catering orders — event jobs surfaced on /operations/catering-orders.
    // Operations team (owners + managers + any signed-in staff) can create,
    // edit, and delete orders; everyone signed in can read.
    match /catering_orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Catering orders the owner has chosen to hide from the app's
    // calendar (Square remains untouched — this collection is the only
    // record of the hide). Written only by /api/catering-orders/[orderId]
    // DELETE via the admin SDK; the client never reads or writes it.
    match /catering_hidden/{orderId} {
      allow read, write: if isOwner();
    }

    // Owner's daily "Today's Sales Review" notes on the dashboard, keyed
    // by YYYY-MM-DD. Owner-only for both reads and writes — this is
    // internal commentary that shouldn't leak beyond owner-level accounts.
    match /sales_reviews/{dateISO} {
      allow read, write: if isOwner();
    }

    // Daily gross sales snapshot — keyed by YYYY-MM-DD. Populated by the
    // Square sync cron (server admin bypass) AND by the owner dashboard
    // whenever it fetches fresh stats, so past days keep their number
    // even if Square is unreachable later. Signed-in read (Insights
    // dashboard consumes it too), owner-only write from the client.
    match /sales_daily/{dateISO} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Local overrides for Square Labor shifts — owner-edited start/end
    // times that stay in Firestore only (never pushed back to Square).
    // Doc id matches the Square shift id so we can join in the client.
    match /timesheet_edits/{shiftId} {
      allow read, write: if isOwner();
    }

    // App-local shifts backfilled by the owner when Square Labor missed
    // a clock-in / clock-out. These are NEVER pushed to Square either;
    // they appear alongside the Square feed in the timesheets UI only.
    match /timesheet_extra_shifts/{docId} {
      allow read, write: if isOwner();
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
