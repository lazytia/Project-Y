rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Owners are identified by the synthetic email we mint from usernames
    // (see src/lib/username.ts → usernameToEmail). Keep this list in sync with
    // OWNER_USERNAMES in src/lib/permissions.ts.
    function isOwner() {
      return request.auth != null
        && request.auth.token.email in [
          "tia@projecty.local",
          "yurica@projecty.local",
          "yurina@projecty.local"
        ];
    }

    // Staff onboarding:
    //  - Any signed-in user can read (manager view at /people/onboarding lists
    //    every doc; the app's sign-in is currently restricted to owner accounts).
    //  - Staff can write their OWN doc (onboarding form progress).
    //  - Owners can write ANY staff doc (seeding new staff accounts from the
    //    Staff + page, sending reminders, pruning invalid FCM tokens, etc.).
    match /staff_onboarding/{uid} {
      allow read: if request.auth != null;
      allow write: if isOwner()
        || (request.auth != null && request.auth.uid == uid);
    }

    // Published rosters: weekly docs keyed by Monday ISO date. Manager
    // notes and per-day shift counts live here. Staff need read access
    // so the staff roster page can display the same data.
    match /rosters_published/{weekStartISO} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Weekly Square gross sales — written by the Square sync job
    // (server) every cron tick. Read by the Insights dashboard.
    match /sales_weekly/{weekStartISO} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Weekly payroll totals — written by the Xero sync job (server)
    // or by an owner via a manual entry form, read by the Insights
    // dashboard. Documents are keyed by the Monday ISO date of the
    // pay-run's work week and contain { gross, super, payDate }.
    match /payroll_weekly/{weekStartISO} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // Cash payments: owner + manager only. Tracks every recorded
    // cash payment to candidates or active employees.
    match /cash_payments/{paymentId} {
      allow read, write: if isOwner();
    }

    // HR notes: manager-only. Each note records a Formal Warning,
    // Performance Review, Incident Report, or Other note for a staff
    // member. Staff never see this collection.
    match /hr_notes/{noteId} {
      allow read, write: if isOwner();
    }

    // Notice Given: records employees who have submitted resignation notice.
    // Owner-only read/write.
    match /notice_given/{noticeId} {
      allow read, write: if isOwner();
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
