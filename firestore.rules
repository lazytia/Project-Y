rules_version = '2';

service cloud.firestore {
  match /databases/project-y/documents {

    // Staff onboarding:
    //  - Any signed-in user can read (manager view at /people/onboarding lists
    //    every doc; the app's sign-in is currently restricted to owner accounts).
    //  - Writes are restricted to the user's own doc so staff can't edit each
    //    other's onboarding.
    match /staff_onboarding/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
